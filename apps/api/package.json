{
  "name": "@sellzy/api",
  "version": "1.0.0",
  "description": "Backend API for Kids Store platform",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node dist/server.js",
    "dev": "nodemon -e ts,js --exec tsx server.ts",
    "build": "tsc || exit 0",
    "webhook": "stripe listen --forward-to localhost:8000/api/payment/webhook",
    "dev:with-webhook": "echo '⚠️  Run these commands in separate terminals:\n  1. pnpm run dev\n  2. pnpm run webhook\n\nOr use concurrently: pnpm install -g concurrently && concurrently \"pnpm run dev\" \"pnpm run webhook\"'",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "generate-slugs": "tsx scripts/generateProductSlugs.js",
    "test": "jest",
    "seed": "tsx scripts/importSeed.ts",
    "export-seed": "tsx scripts/exportSeed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1005.0",
    "@aws-sdk/s3-request-presigner": "^3.1005.0",
    "@eslint/js": "^9.39.4",
    "@imagekit/nodejs": "^7.3.0",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.9.0",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "country-state-city": "^3.2.1",
    "dotenv": "^17.3.1",
    "eslint": "^9.39.4",
    "express": "^5.2.1",
    "express-async-handler": "^1.2.0",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^8.3.2",
    "firebase-admin": "^13.8.0",
    "globals": "^17.4.0",
    "helmet": "^8.1.0",
    "hpp": "^0.2.3",
    "imagekit": "^6.0.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.2.4",
    "multer": "^2.1.1",
    "multer-s3": "^3.0.1",
    "node-fetch": "^3.3.2",
    "nodemailer": "^8.0.2",
    "sharp": "^0.34.5",
    "stripe": "^20.4.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "typescript-eslint": "^8.58.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-rate-limit": "^6.0.2",
    "@types/helmet": "^4.0.0",
    "@types/hpp": "^0.2.7",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/multer-s3": "^3.0.3",
    "@types/node": "^25.4.0",
    "@types/nodemailer": "^7.0.11",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "nodemon": "^3.1.14",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
