# =============================================================================
# Sellzy API – Environment Variables Template
# -----------------------------------------------------------------------------
# Copy this file to `apps/api/.env` and fill in real values.
#   cp apps/api/.env.example apps/api/.env
# Every group below has a comment block telling you exactly where to obtain
# the credentials. Do NOT commit your real .env file.
# =============================================================================


# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
PORT=8000
NODE_ENV=development

# Public URLs of each app. Used by the API for CORS, e-mail links, OAuth
# redirects, Stripe success/cancel URLs etc.
ADMIN_URL=http://localhost:5173
CLIENT_URL=http://localhost:3000
SERVER_URL=http://localhost:8000

# Production overrides (set these on the host when NODE_ENV=production)
PRODUCTION_ADMIN_URL=https://admin.your-domain.com
PRODUCTION_CLIENT_URL=https://your-domain.com
PRODUCTION_SERVER_URL=https://api.your-domain.com


# -----------------------------------------------------------------------------
# MongoDB – https://www.mongodb.com/cloud/atlas
#   1. Create a free cluster on Atlas.
#   2. Database Access  → add a user with read/write to your DB.
#   3. Network Access   → allow your IP (or 0.0.0.0/0 for development).
#   4. Connect → "Drivers" → copy the SRV connection string.
# -----------------------------------------------------------------------------
MONGO_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.example.mongodb.net/sellzy?retryWrites=true&w=majority


# -----------------------------------------------------------------------------
# JWT – any long random string. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# -----------------------------------------------------------------------------
JWT_SECRET=replace-with-a-long-random-string


# -----------------------------------------------------------------------------
# Stripe – https://dashboard.stripe.com/test/apikeys
#   1. Toggle "Test mode" on top-right.
#   2. Copy the "Secret key" (starts with sk_test_…).
#   3. For STRIPE_WEBHOOK_SECRET, run locally:
#        stripe listen --forward-to localhost:8000/api/payments/webhook
#      and copy the whsec_… value it prints.
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME


# -----------------------------------------------------------------------------
# Tax & shipping defaults (override per-store from the admin panel)
# -----------------------------------------------------------------------------
TAX_RATE=0
FREE_DELIVERY_THRESHOLD=999


# -----------------------------------------------------------------------------
# ImageKit – https://imagekit.io/dashboard/developer/api-keys
#   Used as the default media provider. Free tier is sufficient for evaluation.
# -----------------------------------------------------------------------------
IMAGEKIT_PUBLIC_KEY=public_REPLACE_ME
IMAGEKIT_PRIVATE_KEY=private_REPLACE_ME
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_id/sellzy


# -----------------------------------------------------------------------------
# Cloudinary (optional fallback) – https://console.cloudinary.com/settings/api-keys
# -----------------------------------------------------------------------------
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=000000000000000
CLOUDINARY_API_SECRET=replace-me


# -----------------------------------------------------------------------------
# AWS S3 (optional) – https://console.aws.amazon.com/iam/home#/users
#   Create an IAM user with `AmazonS3FullAccess` (or a least-privilege policy
#   scoped to your bucket).
# -----------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=AKIA_REPLACE_ME
AWS_SECRET_ACCESS_KEY=replace-me
AWS_REGION=us-east-1
AWS_S3_BUCKET_NAME=your-bucket-name


# -----------------------------------------------------------------------------
# Upload provider switch
#   One of: imagekit | cloudinary | s3
# -----------------------------------------------------------------------------
DEFAULT_UPLOAD_PROVIDER=imagekit
MAX_PRODUCT_IMAGES=6
DEFAULT_USER_IMAGE=https://res.cloudinary.com/demo/image/upload/v1/defaultUserImage.png


# -----------------------------------------------------------------------------
# SMTP (transactional e-mail) – e.g. Gmail App Password
#   https://myaccount.google.com/apppasswords  (must enable 2-Step Verification)
#   Or use SendGrid / Mailgun / Resend by adjusting host & port.
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASS=your-app-password
SENDER_EMAIL_ADDRESS=you@example.com


# -----------------------------------------------------------------------------
# SSLCommerz (Bangladesh payment gateway, optional)
#   https://developer.sslcommerz.com/  → Sandbox credentials
# -----------------------------------------------------------------------------
SSLCOMMERZ_STORE_ID=your_store_id
SSLCOMMERZ_STORE_PASSWORD=your_store_password
SSLCOMMERZ_IS_LIVE=false


# -----------------------------------------------------------------------------
# Firebase Admin SDK (used for OAuth verification)
#   https://console.firebase.google.com/
#     → Project settings → Service accounts → "Generate new private key"
#   Then JSON.stringify the downloaded JSON into a single line and paste below.
# -----------------------------------------------------------------------------
FIREBASE_SERVICE_ACCOUNT='{"type":"service_account","project_id":"your-project-id","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"firebase-adminsdk@your-project-id.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"...","universe_domain":"googleapis.com"}'
