# =============================================================================
# Sellzy Admin (Vite + React dashboard) – Environment Variables Template
# -----------------------------------------------------------------------------
# Copy this file to `apps/admin/.env` and fill in real values:
#   cp apps/admin/.env.example apps/admin/.env
# Vite exposes any variable prefixed with VITE_ to the browser bundle. Do
# NOT put server-only secrets in this file.
# =============================================================================


# -----------------------------------------------------------------------------
# Backend connection
# -----------------------------------------------------------------------------
VITE_NEXT_PUBLIC_API_URL=http://localhost:8000
CLIENT_URL=http://localhost:5173


# -----------------------------------------------------------------------------
# Build mode marker. Use "production" only for production builds.
# -----------------------------------------------------------------------------
VITE_APP_ENV=development


# -----------------------------------------------------------------------------
# Firebase Web SDK – https://console.firebase.google.com/
#   Project settings → "Your apps" → Web app → "SDK setup and configuration"
#   These are intentionally public client-side values; security is enforced
#   by Firebase Security Rules + the API's Firebase Admin SDK verification.
# -----------------------------------------------------------------------------
VITE_FIREBASE_API_KEY=AIzaSy_REPLACE_ME
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:abc123
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX
