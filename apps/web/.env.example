# =============================================================================
# Sellzy Web (Next.js storefront) – Environment Variables Template
# -----------------------------------------------------------------------------
# Copy this file to `apps/web/.env` and fill in real values:
#   cp apps/web/.env.example apps/web/.env
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser, so put no
# secrets there. Server-only secrets use plain (non-prefixed) names.
# =============================================================================


# -----------------------------------------------------------------------------
# Backend connection
#   Where the storefront calls the API. Point this at the deployed API URL
#   in production (e.g. https://api.your-domain.com).
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_ADMIN_URL=http://localhost:5173


# -----------------------------------------------------------------------------
# Firebase Web SDK – https://console.firebase.google.com/
#   Project settings → "Your apps" → Web app → "SDK setup and configuration"
#   These values are embedded in the bundle (Firebase web config is intended
#   to be public; access is gated by your Firebase Security Rules).
# -----------------------------------------------------------------------------
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSy_REPLACE_ME
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:abc123


# -----------------------------------------------------------------------------
# Storefront defaults (can also be controlled from Admin → Settings)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_VAT_PERCENTAGE=0
NEXT_PUBLIC_SHIPPING_COST=0


# -----------------------------------------------------------------------------
# Optional: ThemeForest design reference link surfaced in marketing pages.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_DESIGN_LINK=https://themeforest.net/item/sellzy-multivendor-ecommerce-tailwind-css-template/61363469
