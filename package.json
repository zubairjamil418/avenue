{
  "name": "sellzy-ecommerce",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:api": "turbo run dev --filter=@sellzy/api",
    "dev:web": "turbo run dev --filter=@sellzy/web",
    "dev:admin": "turbo run dev --filter=@sellzy/admin",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "clean": "rm -rf .turbo node_modules/.cache apps/*/.turbo apps/*/.next apps/*/dist apps/*/node_modules/.cache",
    "seed": "pnpm --filter @sellzy/api run seed",
    "export-seed": "pnpm --filter @sellzy/api run export-seed"
  },
  "devDependencies": {
    "prettier": "^3.8.1",
    "turbo": "^2.8.15",
    "typescript": "5.9.3"
  },
  "packageManager": "pnpm@10.29.3",
  "engines": {
    "node": ">=18"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "19.2.14",
      "@types/react-dom": "19.2.3"
    }
  }
}
